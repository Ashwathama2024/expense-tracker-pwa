# SECURITY NOTE: this app is a client-side-only PWA with no backend server.
# This key is fetched directly from the browser to call OpenAI's API for
# receipt parsing, so it MUST be prefixed with NEXT_PUBLIC_ to be available
# client-side — which also means it is visible in browser devtools and
# network requests to anyone who has access to this device. This is an
# accepted tradeoff for a personal, single-user tool. Do not reuse this
# pattern for a multi-user app.
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-key-here
